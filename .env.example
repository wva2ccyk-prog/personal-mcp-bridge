# personal-mcp-bridge configuration (copy to .env or export in your shell).
#
# Allowlisted roots: semicolon-separated alias=absolute_path pairs.
# With no roots configured, every request is blocked (fail closed).
# BRIDGE_ROOTS="notes=/path/to/notes;docs=/path/to/work/docs"

# Bind address. Default is loopback. Only change this if you understand the
# exposure implications and have set public-mode safety variables below.
# BRIDGE_HOST=127.0.0.1
# BRIDGE_PORT=8787

# Public/tunnel mode. Set to 1 ONLY if this process is intentionally reachable
# off-localhost. In this mode the bridge fails closed: a strong BRIDGE_TOKEN is
# required, ?token= URL auth is refused, and local paths are never emitted.
# BRIDGE_PUBLIC_MODE=0
# BRIDGE_TUNNEL_MODE=0

# Bearer token for the dedicated read-only endpoints. Required (>=32 chars) in
# public/tunnel mode. Present it as: Authorization: Bearer <token>
# BRIDGE_TOKEN=

# Local/dev convenience only. Never honoured in public mode.
# ALLOW_QUERY_TOKEN_AUTH=0
# INCLUDE_LOCAL_PATHS=0
